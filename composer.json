{
    "name": "vardanm1993/laravel-alias-manager",
    "description": "A professional alias and shortcut manager for Laravel, PHP, Sail, Composer, Git, npm, Vite, Pest, Pint, Rector, and PHPStan workflows.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "php",
        "aliases",
        "shortcuts",
        "artisan",
        "sail",
        "composer",
        "cli",
        "shell"
    ],
    "homepage": "https://github.com/vardanm1993/laravel-alias-manager",
    "support": {
        "issues": "https://github.com/vardanm1993/laravel-alias-manager/issues",
        "source": "https://github.com/vardanm1993/laravel-alias-manager"
    },
    "authors": [
        {
            "name": "Vardan",
            "email": "vardanm1993@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "Vardanm1993\\LaravelAliasManager\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vardanm1993\\LaravelAliasManager\\LaravelAliasManagerServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
